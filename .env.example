# Copy to .env and fill values
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MAX_RETRIES=4
GROQ_RETRY_BASE_SECONDS=2

# Optional alternative providers
HF_API_TOKEN=your_huggingface_token
HF_LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
HF_MAX_RETRIES=4
HF_RETRY_BASE_SECONDS=2
HF_FALLBACK_TO_MISTRAL=false

MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_MODEL=mistral-small-latest
MISTRAL_MAX_RETRIES=4
MISTRAL_RETRY_BASE_SECONDS=2

# Cohere API for embeddings
COHERE_API_KEY=your_cohere_api_key

# Storage
STORAGE_DIR=storage
CHROMA_PERSIST_DIR=storage/chroma_db
CHROMA_COLLECTION_NAME=docs
BM25_INDEX_PATH=storage/bm25_index.json

# Chunking
CHUNK_SIZE=700
CHUNK_OVERLAP=100

# Retrieval
TOP_K=5
RETRIEVAL_MODE=hybrid

# Streamlit -> API
API_URL=http://localhost:8000
